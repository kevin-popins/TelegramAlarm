<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/china_background"
        android:scaleType="centerCrop" />

    <View
        android:id="@+id/gradientOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/background_overlay" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- HOME TAB -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/homeContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tabBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ЛОГО ПОД ВЕТОЧКАМИ -->
            <ImageView
                android:id="@+id/appLogo"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:src="@drawable/logo"
                android:adjustViewBounds="true"
                android:scaleType="centerInside"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- КНОПКА КОТА -->
            <ImageButton
                android:id="@+id/trackingToggle"
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/toggle_button_off"
                android:src="@drawable/kevin_off"
                android:scaleType="centerInside"
                android:contentDescription="@string/tracking_cd"
                app:layout_constraintTop_toBottomOf="@id/appLogo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- НАДПИСЬ ПОД КНОПКОЙ -->
            <TextView
                android:id="@+id/trackingStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/tracking_off"
                android:textAlignment="center"
                android:gravity="center"
                android:textColor="@color/text_brown"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/trackingToggle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- SETTINGS TAB -->
        <ScrollView
            android:id="@+id/settingsContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tabBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="96dp"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/currentChatInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_intro"
                    android:textColor="@color/text_brown"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp"
                    android:includeFontPadding="false"
                    android:singleLine="false"
                    android:ellipsize="none"
                    android:maxLines="10"
                    android:scrollHorizontally="false" />

                <EditText
                    android:id="@+id/chatNameEdit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/edit_text_bg"
                    android:hint="@string/chat_names_hint"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#B3FFFFFF"
                    android:inputType="textCapSentences" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveChatButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/alarm_button_background"
                    app:backgroundTint="@null"
                    android:backgroundTint="@null"
                    android:text="@string/btn_save_chats"
                    android:textAllCaps="true"
                    android:textColor="@color/alarm_button_text"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:gravity="center" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/selectSoundButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/alarm_button_background"
                    app:backgroundTint="@null"
                    android:backgroundTint="@null"
                    android:text="@string/btn_pick_sound"
                    android:textAllCaps="true"
                    android:textColor="@color/alarm_button_text"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/selectedSoundText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/sound_not_selected"
                    android:textColor="@color/text_brown"
                    android:textSize="14sp" />

                <!-- ПОДПИСЬ ДЛЯ ГРОМКОСТИ -->
                <TextView
                    android:id="@+id/volumeLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/volume_label_default"
                    android:textColor="@color/text_brown"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- ПОЛЗУНОК ГРОМКОСТИ -->
                <SeekBar
                    android:id="@+id/alarmVolumeSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:progress="70"
                    android:max="100"
                    android:progressTint="@color/volume_color"
                    android:thumbTint="@color/volume_color" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openNotificationSettingsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="@drawable/alarm_button_background"
                    app:backgroundTint="@null"
                    android:backgroundTint="@null"
                    android:text="@string/btn_open_notif_access"
                    android:textAllCaps="true"
                    android:textColor="@color/alarm_button_text"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:lineSpacingExtra="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/disableBatteryOptimizationButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="@drawable/alarm_button_background"
                    app:backgroundTint="@null"
                    android:backgroundTint="@null"
                    android:text="@string/btn_disable_battery"
                    android:textAllCaps="true"
                    android:textColor="@color/alarm_button_text"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:lineSpacingExtra="2dp" />

                <!-- LANGUAGE -->
                <TextView
                    android:id="@+id/languageSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/language_section_title"
                    android:textColor="@color/text_brown"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/languageButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/alarm_button_background"
                    app:backgroundTint="@null"
                    android:backgroundTint="@null"
                    android:text="@string/btn_choose_language"
                    android:textAllCaps="true"
                    android:textColor="@color/alarm_button_text"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:gravity="center" />

            </LinearLayout>
        </ScrollView>

        <!-- INFO TAB -->
        <ScrollView
            android:id="@+id/infoContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tabBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="96dp"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/infoTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/info_title"
                    android:textColor="@color/text_brown"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:id="@+id/infoGuideText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/text_brown"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/info_guide" />

            </LinearLayout>
        </ScrollView>

        <!-- TAB BAR -->
        <LinearLayout
            android:id="@+id/tabBar"
            android:layout_width="0dp"
            android:layout_height="124dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginBottom="40dp"
            android:background="@android:color/transparent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- HOME -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconHome"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/home_icon"
                    android:tint="@color/black" />

                <TextView
                    android:id="@+id/tabHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_home"
                    android:textAllCaps="true"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_brown"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- SETTINGS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconSettings"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/settings_icon"
                    android:tint="#80FFFFFF" />

                <TextView
                    android:id="@+id/tabSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_settings"
                    android:textAllCaps="true"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#80FFFFFF"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- INFO -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iconInfo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/info"
                    android:tint="#80FFFFFF" />

                <TextView
                    android:id="@+id/tabInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_info"
                    android:textAllCaps="true"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#80FFFFFF"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
