<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Внутри полностью прозрачно -->
    <solid android:color="@android:color/transparent" />

    <!-- Золотой контур -->
    <stroke
        android:width="3dp"
        android:color="@color/accent_gold" />

    <!-- Отступ, чтобы кот был меньше окружности -->
    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp" />
</shape>
